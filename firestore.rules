rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation helpers
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['gameId', 'title', 'addedAt']) &&
             data.keys().size() <= 8 &&
             data.gameId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.addedAt == request.time;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'updatedAt']) &&
                    request.resource.data.updatedAt == request.time;
      
      // Wishlist subcollection
      match /wishlist/{gameId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(gameId) && isValidWishlistItem(request.resource.data);
        allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['targetPrice', 'currentBestPrice', 'lastNotifiedPrice']) &&
                      isValidWishlistItem(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
